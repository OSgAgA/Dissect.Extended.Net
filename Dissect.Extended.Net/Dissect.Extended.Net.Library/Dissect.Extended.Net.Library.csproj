<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <PropertyGroup>
    <TargetFrameworks>net8.0;net10.0</TargetFrameworks>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageTags>dissect;parser;log-parser;log-parsing;text-parsing;structured-logging</PackageTags>
    <RepositoryUrl>https://github.com/OSgAgA/Dissect.Extended.Net</RepositoryUrl>
    <RepositoryType>git</RepositoryType>

    <PackageId>Dissect.Extended.Net</PackageId>
    <Authors>OSgAgA</Authors>
    <Description>
      A Dissect parser extracts structured data from a string by matching it against a predefined pattern. The parser compares the input string with the pattern and splits the input according to the Dissect rules.

      This .NET implementation is fully compatible with the original specification while adding support for typed values beyond strings. It also provides a way to define append separators directly within the pattern.
    </Description>

    <GeneratePackageOnBuild>false</GeneratePackageOnBuild>
  </PropertyGroup>
  
  <ItemGroup>
    <None Include="..\..\README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
